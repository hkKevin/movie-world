.carousel .slide img {
  max-width: 100%;
  height: auto;
}

#movieInfo {
  grid-column: 2/4;
  margin: 0 2vh;
}

#movieIntro {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
}

#left {
  text-align: left;
}

#movieTitle {
  font-size: 4vh;
  line-height: 6vh;
  margin-top: 0;  
  margin-bottom: 1vh;
  text-align: left;
}

#yearRuntimeRatingHomepage {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  color: gray;
  margin-top: 1.5vh;
}

#yearRuntimeRatingHomepage i {
  margin-right: 1vh;
}

#denominator {
  font-size: 1.7vh;
}

#homepageIcon {
  color: gray;
}

#homepageIcon:hover {
  color: #efe1b1;
}

#movieDetails {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
}

#left {
  padding: 2vh 0;
}

#right {
  text-align: left;
}

#budgetRevenueContainer {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-column: 2/4;
  color: gray;
}

#budgetRevenueContainer p {
  margin-top: 0;
}

#castContainer {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  margin: 3vh 0;
}

.castProfilePic > img {
  width: 100px;
}

#videoContainer {
  margin-bottom: 8vh;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1em;
}

#reviewText {
  /* font-size: 2vh; */
  text-align: left;
  margin-bottom: 2vh;
}

.accordion {
  margin-bottom: 4em;
}

.accordion__title {
  color: #0b1434;
  background: #efe1b1;
  outline: none;
  padding: .2em 1em;
  width: auto;
}

.accordion__title p {
  margin-top: 0;
}

.accordion__title:hover {
  background: #ebdba1;
}

.accordion__body {
  text-align: left;
  border: none;
  padding: 0 30vh;
  white-space: pre-wrap;
  margin-bottom: 3em;
}














@media (max-width: 1150px) {
  #videoContainer iframe {
    margin: 1vh auto;
    width: 480px;
    height: 270px;
  }
}

@media (max-width: 1030px) {
  #videoContainer {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
}

@media (max-width: 950px) {
  .accordion__body {
    padding: 0 20vh;
  }  
}

@media (max-width: 900px) {
  #movieIntro {
    display: grid;
    grid-template-columns: 1fr;
  }

  #movieTitle {
    text-align: center;
  }

  #movieDetails {
    display: grid;
    grid-template-columns: 1fr;
  }

  #left {
    display: grid;
    grid-template-columns: 1fr;
    margin: auto;
  }
}

@media (max-width: 700px) {
  .accordion__body {
    padding: 0 15vh;
  }  
}

@media (max-width: 620px) {
  .accordion__body {
    padding: 0 10vh;
  }  
}

@media (max-width: 560px) {
  body {
    font-size: 2.3vh;
  }

  #videoContainer iframe {
    margin: 1vh auto;
    width: 272px;
    height: 153px;
  }
  
  .castProfilePic > img {
    width: 70px;
  }

  #budgetRevenueContainer {
    display: grid;
    grid-template-columns: 1fr;
  }

  .accordion__body {
    padding: 0;
  }
}

@media (max-width: 500px) {
  #yearRuntimeRatingHomepage {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 400px) {

  body {
    font-size: 2.5vh;
  }

  #movieInfo {
    margin: 0 2.5vh;
  }

  .castProfilePic > img {
    width: 50px;
  }

  #left img {
    width: 70%;
    margin: auto;
  }

}